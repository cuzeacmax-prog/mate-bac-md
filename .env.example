# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — console.anthropic.com → API Keys (chat tutore, decompose, verify)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — platform.openai.com → API Keys (TTS voice mode; opțional embeddings)
OPENAI_API_KEY=sk-...

# Google AI Studio — aistudio.google.com (embeddings RAG: gemini-embedding-001)
GOOGLE_GENERATIVE_AI_API_KEY=...

# Provider embeddings: 'gemini' (default) sau 'openai' — vezi src/lib/embeddings/index.ts
# EMBEDDING_PROVIDER=gemini

# Serviciul de compilare TikZ→SVG (Railway) — folosit de calculatoarele din chat
TIKZ_COMPILE_URL=https://your-tikz-service.up.railway.app

# PostHog analytics (opțional)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://eu.i.posthog.com

# URL-ul public al aplicației (linkuri de referral)
NEXT_PUBLIC_APP_URL=http://localhost:3000
